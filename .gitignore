# OS / filesystem noise
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Local environment files
.env
.env.*
!.env.example

# Runtime logs and debug output
*.log
*.tmp
*.cache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local archives / backups
*.zip
*.tar
*.tar.gz
*.bak
*.old

# Dependency/build artifacts (if local tooling is used)
node_modules/
dist/
build/
coverage/

# Package manager lockfiles (keep if you adopt Node in this repo)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Credentials and private keys
*.pem
*.key
*.p12
*.pfx
*.crt

# Local Vapi/private config conventions
vapi/secrets/
vapi/**/*.local.json
vapi/**/*.local.yaml
vapi/**/*.local.yml
vapi/**/*.txt
