{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "nexdine/vapi-agent-trigger",
  "version": "0.1.0",
  "title": "Vapi Agent Trigger",
  "category": "widgets",
  "icon": "phone",
  "description": "Render a Vapi trigger button that uses a selected configured Vapi agent.",
  "textdomain": "nexdine",
  "attributes": {
    "assistantId": {
      "type": "string",
      "default": ""
    },
    "designVariation": {
      "type": "string",
      "default": "default"
    }
  },
  "supports": {
    "html": false
  },
  "editorScript": "file:./edit.js",
  "viewScript": "file:./view.js",
  "style": "file:./style.css",
  "editorStyle": "file:./style.css",
  "render": "file:./render.php"
}
